#!/bin/bash

set -e

./gradlew clean shadowJar

JAR_PATH="build/libs/GleamStorm-1.0-SNAPSHOT-all.jar"
if [ ! -f "$JAR_PATH" ]; then
    echo "JAR file not found: $JAR_PATH"
    exit 1
fi

cat > gleamstorm << 'EOF'
#!/bin/bash
TEMP_JAR=$(mktemp)
trap "rm -f $TEMP_JAR" EXIT
tail -n +__JAR_LINE__ "$0" | base64 -D > "$TEMP_JAR"
if ! command -v java &> /dev/null; then
    echo "Java not found"
    exit 1
fi
exec java -jar "$TEMP_JAR" "$@"
EOF

JAR_LINE=$(($(wc -l < gleamstorm) + 1))
sed -i.bak "s/__JAR_LINE__/$JAR_LINE/" gleamstorm
rm gleamstorm.bak

base64 -i "$JAR_PATH" >> gleamstorm

chmod +x gleamstorm
